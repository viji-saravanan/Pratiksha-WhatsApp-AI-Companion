# Viji Helper local environment template.
# Keep this file in sync with .env whenever new configuration is introduced.

# Core runtime
VIJI_DATA_ROOT="/Volumes/Arya 1TB/VijiAI"
VIJI_STORAGE_PROFILE="large-200gb"
VIJI_SENTINEL_FILE=".viji-helper-root"
VIJI_ASSISTANT_NAME="Pratiksha"
VIJI_ASSISTANT_REPLY_PREFIX="[Pratiksha]"
VIJI_AUTO_REPLY_ENABLED="false"
VIJI_DEFAULT_REPLY_MODE="auto"
VIJI_RESOURCE_ROOT="/Volumes/Arya 1TB/VijiAI/viji-files"
VIJI_API_HOST="127.0.0.1"
VIJI_API_PORT="8787"
VIJI_API_BASE_URL="http://127.0.0.1:8787"
VIJI_API_TOKEN="local-dev-token"
VIJI_DASHBOARD_HOST="127.0.0.1"
VIJI_DASHBOARD_PORT="8788"
VIJI_DASHBOARD_API_BASE_URL="http://127.0.0.1:8787"
VIJI_DASHBOARD_DOCKER_API_BASE_URL="http://api:8787"
VIJI_CONTAINER_LOGS_ENABLED="true"
VIJI_DOCKER_SOCKET_PATH="/var/run/docker.sock"
VIJI_DOCKER_COMPOSE_PROJECT="viji-helper"
VIJI_CONTAINER_LOGS_TAIL="120"
VIJI_CONTAINER_LOGS_TIMEOUT_MS="5000"
VIJI_DASHBOARD_UPLOAD_MAX_BYTES="52428800"
VIJI_WACLI_BIN="wacli"
VIJI_WACLI_STORE="/Volumes/Arya 1TB/VijiAI/wacli/store"
VIJI_WACLI_BACKUP_ROOT="/Volumes/Arya 1TB/VijiAI/wacli/backup"
VIJI_WACLI_PREFLIGHT_SYNC_ENABLED="true"
VIJI_WACLI_PREFLIGHT_SYNC_IDLE_EXIT="30s"
VIJI_WACLI_PREFLIGHT_SYNC_MAX_RECONNECT="45s"
VIJI_WACLI_PREFLIGHT_SYNC_REFRESH_CONTACTS="true"
VIJI_WACLI_PREFLIGHT_SYNC_REFRESH_GROUPS="false"
VIJI_WACLI_PREFLIGHT_SYNC_TIMEOUT_MS="90000"
VIJI_WACLI_PREFLIGHT_REQUIRED_CHAT_QUERIES=""
VIJI_WACLI_PREFLIGHT_CHAT_CHECK_TIMEOUT_MS="15000"
VIJI_WACLI_MEDIA_ROOT="/Volumes/Arya 1TB/VijiAI/wacli/media"
VIJI_WACLI_TIMEOUT="30s"
VIJI_WACLI_SYNC_TIMEOUT="75s"
VIJI_WACLI_MARK_READ_BIN="wacli-mark-read"
VIJI_WACLI_MARK_READ_ENABLED="true"
VIJI_WACLI_MARK_READ_TIMEOUT="5s"
VIJI_WACLI_LIVE_SMOKE_ENABLED="false"
VIJI_WACLI_LIVE_READ_SMOKE_ENABLED="false"
VIJI_WACLI_LIVE_READ_SMOKE_QUERY="Vijayalakshmi Saravanan"
VIJI_WACLI_LIVE_READ_SMOKE_CHAT_LIMIT="5"
VIJI_WACLI_LIVE_READ_SMOKE_MESSAGE_LIMIT="5"
VIJI_WACLI_LIVE_RECOVERY_SMOKE_ENABLED="false"
VIJI_WACLI_LIVE_RECOVERY_SMOKE_AFTER=""
VIJI_WACLI_LIVE_SEND_ENABLED="false"
VIJI_WACLI_LIVE_SEND_SMOKE_ENABLED="false"
VIJI_WACLI_LIVE_SEND_SMOKE_TO=""
VIJI_WACLI_LIVE_SEND_SMOKE_MESSAGE="Pratiksha live send smoke test."
VIJI_LIVE_INGEST_CONTACT_LIMIT="100"
VIJI_LIVE_INGEST_CHAT_SEARCH_LIMIT="5"
VIJI_LIVE_INGEST_MESSAGE_LIMIT="25"
VIJI_LIVE_POLL_INTERVAL_MS="1000"
VIJI_LIVE_SYNC_BEFORE_POLL_ENABLED="false"
VIJI_LIVE_SYNC_SCHEDULER_ENABLED="true"
VIJI_LIVE_STARTUP_SYNC_ENABLED="true"
VIJI_LIVE_SYNC_INTERVAL_MS="60000"
VIJI_LIVE_SYNC_RETRY_MIN_MS="15000"
VIJI_LIVE_SYNC_RETRY_MAX_MS="300000"
VIJI_LIVE_SYNC_JITTER_RATIO="0.15"
VIJI_LIVE_SYNC_IDLE_EXIT="12s"
VIJI_LIVE_SYNC_REFRESH_CONTACTS="false"
VIJI_LIVE_SYNC_REFRESH_GROUPS="false"
VIJI_LIVE_AUTOMATION_BATCH_LIMIT="10"
VIJI_LIVE_DISPATCH_LIMIT_PER_CYCLE="5"
VIJI_DEFAULT_CHANNEL_ACCOUNT_ID="00000000-0000-4000-8000-000000000003"

# Primary allowlist seed for Vijayalakshmi. Keep real values in ignored .env only.
VIJI_ALLOWLIST_VIJI_DISPLAY_NAME="Vijayalakshmi Saravanan"
VIJI_ALLOWLIST_VIJI_PHONE_E164=""
VIJI_ALLOWLIST_VIJI_WA_JID=""

# Optional local-only allowlist seed for self-testing. Keep real values in .env only.
VIJI_TEST_ALLOWLIST_MYSELF_ENABLED="false"
VIJI_TEST_ALLOWLIST_MYSELF_DISPLAY_NAME="Myself"
VIJI_TEST_ALLOWLIST_MYSELF_PHONE_E164=""
VIJI_TEST_ALLOWLIST_MYSELF_WA_JID=""

# Local AI runtime
VIJI_LLM_PROVIDER="ollama"
VIJI_LLM_PROXY_HOST="127.0.0.1"
VIJI_LLM_PROXY_PORT="8791"
VIJI_LLM_PROXY_TOKEN="local-llm-token"
VIJI_OLLAMA_BASE_URL="http://127.0.0.1:11434"
VIJI_OLLAMA_DOCKER_BASE_URL="http://host.docker.internal:11434"
VIJI_OLLAMA_MODEL="qwen3:4b-instruct-2507-q4_K_M"
VIJI_OLLAMA_EMBEDDING_MODEL="mxbai-embed-large"
VIJI_OLLAMA_TIMEOUT_MS="120000"
VIJI_OLLAMA_TEMPERATURE="0.2"
VIJI_OLLAMA_NUM_PREDICT="160"
VIJI_OLLAMA_CONTEXT_WINDOW_TOKENS="4096"
OLLAMA_MODELS="/Volumes/Arya 1TB/VijiAI/models/ollama"
OLLAMA_HOST="127.0.0.1:11434"
OLLAMA_NO_CLOUD="1"
OLLAMA_FLASH_ATTENTION="1"
OLLAMA_KV_CACHE_TYPE="q8_0"

# Postgres service
POSTGRES_DB="viji_helper"
POSTGRES_USER="viji"
POSTGRES_PASSWORD="1234"
POSTGRES_PORT="5433"
DATABASE_URL="postgres://viji:1234@localhost:5433/viji_helper"
DATABASE_DOCKER_URL="postgres://viji:1234@postgres:5432/viji_helper"

# Migration runner
VIJI_MIGRATIONS_DIR="migrations"
MIGRATION_COMPOSE_SERVICE="postgres"
MIGRATION_DOCKER_CONTAINER=""
MIGRATION_POSTGRES_DB="viji_helper"
MIGRATION_POSTGRES_USER="viji"
MIGRATION_PSQL_BIN="psql"

# Disposable integration tests
VIJI_TEST_POSTGRES_IMAGE="pgvector/pgvector:pg16"

# Observability service ports
PROMETHEUS_PORT="9090"
LOKI_PORT="3100"
GRAFANA_PORT="3000"
GRAFANA_ADMIN_PASSWORD="1234"

# Backup and retention
VIJI_PGBACKUP_DIR="/Volumes/Arya 1TB/VijiAI/pgbackups"
VIJI_BACKUP_KEEP_COUNT="7"
VIJI_RETENTION_TMP_MAX_AGE_DAYS="7"
